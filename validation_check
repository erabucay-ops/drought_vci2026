// VCI-Precipitation Relationship Check in Representative Climate Regions
// Data used
//   - Asia boundary asset
//   - Monthly precipitation (IMERG)
//   - Month-specific climatological VCI
//   - MODIS land cover
//
// Sample Regions (5° x 5° boxes):
//   1) Indo-Gangetic Plain
//   2) Northern China
//   3) Interior Central Asia
//   4) Lao PDR
//   5) Philippines

// Inputs

var targetYear = 2024; //user may change target year as well as baseline years
var baselineStart = '2003-01-01';
var baselineEnd   = '2023-12-31';

// User-uploaded defined boundary
var asiaBoundary = ee.FeatureCollection(
  'projects/silicon-comfort-205603/assets/vci/AsiaContinentFinal'
);

var asiaBounds = asiaBoundary.geometry().bounds();

// Sample regions at 5° x 5° BOXES

var igpBox = ee.Geometry.Rectangle([77.5, 25.0, 82.5, 30.0]);    // Indo-Gangetic Plain
var ncBox  = ee.Geometry.Rectangle([112.5, 35.0, 117.5, 40.0]);  // Northern China
var caBox  = ee.Geometry.Rectangle([65.0, 42.0, 70.0, 47.0]);    // Interior Central Asia

// Added sample regions
var laoBox = ee.Geometry.Rectangle([100.0, 15.0, 105.0, 20.0]);  // Lao PDR representative
var phBox  = ee.Geometry.Rectangle([120.0, 10.0, 125.0, 15.0]);  // Philippines representative

var regionFC = ee.FeatureCollection([
  ee.Feature(igpBox, {region_id: 'IGP', region_name: 'Indo-Gangetic Plain'}),
  ee.Feature(ncBox,  {region_id: 'NC',  region_name: 'Northern China'}),
  ee.Feature(caBox,  {region_id: 'CA',  region_name: 'Interior Central Asia'}),
  ee.Feature(laoBox, {region_id: 'LAO', region_name: 'Lao PDR'}),
  ee.Feature(phBox,  {region_id: 'PH',  region_name: 'Philippines'})
]);

Map.centerObject(asiaBoundary, 3);
Map.addLayer(asiaBoundary, {color: 'black'}, 'Asia boundary', false);
Map.addLayer(regionFC, {color: 'red'}, 'Diagnostic boxes');


// MODIS derived land cover (reference year: 2024)

var lc2024 = ee.ImageCollection('MODIS/061/MCD12Q1')
  .filterDate('2024-01-01', '2025-01-01')
  .first();

var lcType1 = lc2024.select('LC_Type1');
var landWater = lc2024.select('LW');

// Mask for VCI computation
var validLandMask = landWater.eq(2)
  .and(lcType1.neq(15))   // permanent snow/ice
  .and(lcType1.neq(16));  // barren/sparse

// Mask from uploaded defined boundary
var asiaBoundaryMask = ee.Image.constant(1)
  .clipToCollection(asiaBoundary)
  .rename('asia_boundary_mask')
  .selfMask();

// Combined mask
var finalMask = asiaBoundaryMask.mask().and(validLandMask);

// MODIS derived EVI / VCI

var modisEVI = ee.ImageCollection('MODIS/061/MOD13A2')
  .filterBounds(asiaBounds)
  .select('EVI')
  .map(function(image) {
    return image.divide(10000)
      .copyProperties(image, ['system:time_start']);
  });

var historicalEVI = modisEVI.filterDate(baselineStart, baselineEnd);
var targetEVI = modisEVI.filterDate(targetYear + '-01-01', targetYear + '-12-31');

var months = ee.List.sequence(1, 12);

var monthNamesEE = ee.List([
  'January', 'February', 'March', 'April', 'May', 'June',
  'July', 'August', 'September', 'October', 'November', 'December'
]);

// Month-specific climatological VCI
var monthlyVCI = ee.ImageCollection.fromImages(
  months.map(function(m) {
    m = ee.Number(m);

    var currentMonthEVI = targetEVI
      .filter(ee.Filter.calendarRange(m, m, 'month'))
      .mean()
      .rename('EVI_current');

    var historicalMonth = historicalEVI
      .filter(ee.Filter.calendarRange(m, m, 'month'));

    var monthMin = historicalMonth.reduce(ee.Reducer.min()).rename('EVI_min_m');
    var monthMax = historicalMonth.reduce(ee.Reducer.max()).rename('EVI_max_m');
    var monthRange = monthMax.subtract(monthMin);
    var safeMonthRange = monthRange.where(monthRange.eq(0), 0.0001);

    var vci = currentMonthEVI
      .subtract(monthMin)
      .divide(safeMonthRange)
      .multiply(100)
      .clamp(0, 100)
      .rename('VCI')
      .updateMask(finalMask)
      .clipToCollection(asiaBoundary)
      .set({
        month: m,
        month_name: monthNamesEE.get(m.subtract(1)),
        year: targetYear
      });

    return vci;
  })
);


// IMERG Monthly Precipitation

var imerg = ee.ImageCollection('NASA/GPM_L3/IMERG_V07')
  .filterBounds(asiaBounds)
  .filterDate(targetYear + '-01-01', targetYear + '-12-31')
  .select('precipitation');

var monthlyPrecip = ee.ImageCollection.fromImages(
  months.map(function(m) {
    m = ee.Number(m);

    var monthly = imerg
      .filter(ee.Filter.calendarRange(m, m, 'month'))
      .sum()
      .clipToCollection(asiaBoundary)
      .rename('P')
      .set({
        month: m,
        month_name: monthNamesEE.get(m.subtract(1)),
        year: targetYear
      });

    return monthly;
  })
);


// Map Preview (optional) 

var janVCI = monthlyVCI.filter(ee.Filter.eq('month', 1)).first();
var janP = monthlyPrecip.filter(ee.Filter.eq('month', 1)).first();

Map.addLayer(janVCI, {
  min: 0,
  max: 100,
  palette: ['#7f0000','#b30000','#d7301f','#ef6548','#fc8d59','#fdbb84','#fee08b','#d9ef8b','#a6d96a','#66bd63','#1a9850','#006837']
}, 'January VCI', false);

Map.addLayer(janP, {
  min: 0,
  max: 300,
  palette: ['#f7f7f7','#e3f2fd','#bbdefb','#90caf9','#64b5f6','#42a5f5','#1e88e5','#1565c0','#0d47a1','#4a148c']
}, 'January precipitation', false);


// Land cover summary for the sample regions 

var lcClassNames = ee.Dictionary({
  '1': 'Evergreen Needleleaf Forest',
  '2': 'Evergreen Broadleaf Forest',
  '3': 'Deciduous Needleleaf Forest',
  '4': 'Deciduous Broadleaf Forest',
  '5': 'Mixed Forest',
  '6': 'Closed Shrublands',
  '7': 'Open Shrublands',
  '8': 'Woody Savannas',
  '9': 'Savannas',
  '10': 'Grasslands',
  '11': 'Permanent Wetlands',
  '12': 'Croplands',
  '13': 'Urban and Built-up',
  '14': 'Cropland/Natural Vegetation Mosaic',
  '15': 'Permanent Snow and Ice',
  '16': 'Barren or Sparsely Vegetated',
  '17': 'Water Bodies'
});

function dominantLandCover(feature) {
  var hist = lcType1.reduceRegion({
    reducer: ee.Reducer.frequencyHistogram(),
    geometry: feature.geometry(),
    scale: 500,
    maxPixels: 1e13
  }).get('LC_Type1');

  hist = ee.Dictionary(hist);
  var keys = hist.keys();

  var pairs = keys.map(function(k) {
    k = ee.String(k);
    return ee.Feature(null, {
      class_value: k,
      count: hist.get(k),
      class_name: lcClassNames.get(k)
    });
  });

  var sorted = ee.FeatureCollection(pairs).sort('count', false);
  var top = ee.Feature(sorted.first());

  return feature.set({
    dominant_lc_code: top.get('class_value'),
    dominant_lc_name: top.get('class_name')
  });
}

var regionWithLC = regionFC.map(dominantLandCover);
print('Dominant land cover by diagnostic region', regionWithLC);



// Monthly regional means 

function monthlyMeansForRegion(regionFeature) {
  var geom = regionFeature.geometry();
  var rid = regionFeature.get('region_id');
  var rname = regionFeature.get('region_name');
  var lcname = regionFeature.get('dominant_lc_name');

  var features = months.map(function(m) {
    m = ee.Number(m);

    var pImg = monthlyPrecip.filter(ee.Filter.eq('month', m)).first();
    var vciImg = monthlyVCI.filter(ee.Filter.eq('month', m)).first();

    var pMean = ee.Image(pImg).reduceRegion({
      reducer: ee.Reducer.mean(),
      geometry: geom,
      scale: 10000,
      maxPixels: 1e13
    }).get('P');

    var vciMean = ee.Image(vciImg).reduceRegion({
      reducer: ee.Reducer.mean(),
      geometry: geom,
      scale: 10000,
      maxPixels: 1e13
    }).get('VCI');

    return ee.Feature(null, {
      region_id: rid,
      region_name: rname,
      dominant_lc: lcname,
      month: m,
      month_name: monthNamesEE.get(m.subtract(1)),
      precip_mm: pMean,
      vci_mean: vciMean
    });
  });

  return ee.FeatureCollection(features);
}

var igpMonthly = monthlyMeansForRegion(
  ee.Feature(regionWithLC.filter(ee.Filter.eq('region_id', 'IGP')).first())
);
var ncMonthly = monthlyMeansForRegion(
  ee.Feature(regionWithLC.filter(ee.Filter.eq('region_id', 'NC')).first())
);
var caMonthly = monthlyMeansForRegion(
  ee.Feature(regionWithLC.filter(ee.Filter.eq('region_id', 'CA')).first())
);
var laoMonthly = monthlyMeansForRegion(
  ee.Feature(regionWithLC.filter(ee.Filter.eq('region_id', 'LAO')).first())
);
var phMonthly = monthlyMeansForRegion(
  ee.Feature(regionWithLC.filter(ee.Filter.eq('region_id', 'PH')).first())
);

var allMonthly = igpMonthly
  .merge(ncMonthly)
  .merge(caMonthly)
  .merge(laoMonthly)
  .merge(phMonthly);

print('Monthly precipitation and VCI by region', allMonthly);


// Simple quantitative evaluation 

function correlationFromFC(fc, xProp, yProp) {
  return fc.reduceColumns({
    reducer: ee.Reducer.pearsonsCorrelation(),
    selectors: [xProp, yProp]
  });
}

function addLaggedPrecip(fc) {
  fc = fc.sort('month');
  var list = fc.toList(fc.size());

  var out = ee.List.sequence(0, fc.size().subtract(1)).map(function(i) {
    i = ee.Number(i);
    var f = ee.Feature(list.get(i));

    var lagVal = ee.Algorithms.If(
      i.eq(0),
      null,
      ee.Feature(list.get(i.subtract(1))).get('precip_mm')
    );

    return f.set('precip_lag1', lagVal);
  });

  return ee.FeatureCollection(out);
}

function summarizeRegion(fc, regionName) {
  var sameMonth = correlationFromFC(fc, 'precip_mm', 'vci_mean');
  var lagged = correlationFromFC(
    addLaggedPrecip(fc).filter(ee.Filter.notNull(['precip_lag1', 'vci_mean'])),
    'precip_lag1',
    'vci_mean'
  );

  return ee.Feature(null, {
    region_name: regionName,
    r_precip_vci: sameMonth.get('correlation'),
    p_precip_vci: sameMonth.get('p-value'),
    r_lag1precip_vci: lagged.get('correlation'),
    p_lag1precip_vci: lagged.get('p-value')
  });
}

var summaryFC = ee.FeatureCollection([
  summarizeRegion(igpMonthly, 'Indo-Gangetic Plain'),
  summarizeRegion(ncMonthly,  'Northern China'),
  summarizeRegion(caMonthly,  'Interior Central Asia'),
  summarizeRegion(laoMonthly, 'Lao PDR'),
  summarizeRegion(phMonthly,  'Philippines')
]);

print('VCI-precipitation correlation summary', summaryFC);


