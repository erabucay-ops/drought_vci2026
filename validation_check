function scatterChart(fc, title) {
  return ui.Chart.feature.byFeature(fc, 'precip_mm', ['vci_mean'])
    .setChartType('ScatterChart')
    .setOptions({
      title: title,
      hAxis: {title: 'Monthly precipitation (mm)'},
      vAxis: {title: 'Monthly mean VCI'},
      pointSize: 5,
      trendlines: {0: {showR2: true, visibleInLegend: true}}
    });
}

